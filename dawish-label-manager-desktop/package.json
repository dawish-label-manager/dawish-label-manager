{
  "name": "dawish-label-manager",
  "version": "1.1.2",
  "description": "نظام إدارة الملصقات والباركودات - عطارة الدويش",
  "main": "main.js",
  "author": "Dawish",
  "private": false,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['release','dist']) if (fs.existsSync(p)) fs.rmSync(p,{recursive:true,force:true});\"",
    "build:win": "electron-builder --win nsis",
    "publish:win": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.dawish.labels",
    "productName": "Dawish Label Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dawish Label Manager"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dawish-label-manager",
        "repo": "dawish-label-manager",
        "releaseType": "release"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dawish-label-manager/dawish-label-manager.git"
  },
  "homepage": "https://github.com/dawish-label-manager/dawish-label-manager#readme",
  "bugs": {
    "url": "https://github.com/dawish-label-manager/dawish-label-manager/issues"
  }
}
